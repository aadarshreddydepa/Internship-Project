{
  "testCases": [
    {
      "scenario": "Valid business details",
      "data": {
        "businessName": "Tech Solutions",
        "description": "We provide software development services",
        "category": "Services",
        "subcategory": "Consulting"
      },
      "expected": true
    },
    {
      "scenario": "Empty business name",
      "data": {
        "businessName": "",
        "description": "We provide software development services",
        "category": "Services",
        "subcategory": "Consulting"
      },
      "expected": false
    },
    {
      "scenario": "Business name too short",
      "data": {
        "businessName": "AB",
        "description": "We provide software development services",
        "category": "Services",
        "subcategory": "Consulting"
      },
      "expected": false
    },
    {
      "scenario": "Business name only whitespace",
      "data": {
        "businessName": "   ",
        "description": "We provide software development services",
        "category": "Services",
        "subcategory": "Consulting"
      },
      "expected": false
    },
    {
      "scenario": "Empty description",
      "data": {
        "businessName": "Tech Solutions",
        "description": "",
        "category": "Services",
        "subcategory": "Consulting"
      },
      "expected": false
    },
    {
      "scenario": "Description too short",
      "data": {
        "businessName": "Tech Solutions",
        "description": "Too short",
        "category": "Services",
        "subcategory": "Consulting"
      },
      "expected": false
    },
    {
      "scenario": "Empty category",
      "data": {
        "businessName": "Tech Solutions",
        "description": "We provide software development services",
        "category": "",
        "subcategory": "Consulting"
      },
      "expected": false
    },
    {
      "scenario": "Empty subcategory",
      "data": {
        "businessName": "Tech Solutions",
        "description": "We provide software development services",
        "category": "Services",
        "subcategory": ""
      },
      "expected": false
    }
  ]
}

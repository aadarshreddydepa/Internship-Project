{
  "testCases": [

    {
      "scenario": "Valid contact details",
      "data": {
        "phone": "9876543210",
        "email": "user@gmail.com",
        "website": "https://example.com",
        "address": "MG Road",
        "city": "Mumbai",
        "state": "Maharashtra",
        "pincode": "400001"
      },
      "expected": true
    },

    {
      "scenario": "Phone number less than 10 digits",
      "data": {
        "phone": "987654321",
        "email": "user@gmail.com",
        "website": "https://example.com",
        "address": "MG Road",
        "city": "Mumbai",
        "state": "Maharashtra",
        "pincode": "400001"
      },
      "expected": false
    },

    {
      "scenario": "Phone number starting below 6",
      "data": {
        "phone": "5123456789",
        "email": "user@gmail.com",
        "website": "https://example.com",
        "address": "MG Road",
        "city": "Mumbai",
        "state": "Maharashtra",
        "pincode": "400001"
      },
      "expected": false
    },

    {
      "scenario": "Phone number with all repeating digits",
      "data": {
        "phone": "0000000000",
        "email": "user@gmail.com",
        "website": "https://example.com",
        "address": "MG Road",
        "city": "Mumbai",
        "state": "Maharashtra",
        "pincode": "400001"
      },
      "expected": false
    },

    {
      "scenario": "Email starting with dot",
      "data": {
        "phone": "9876543210",
        "email": ".user@gmail.com",
        "website": "https://example.com",
        "address": "MG Road",
        "city": "Mumbai",
        "state": "Maharashtra",
        "pincode": "400001"
      },
      "expected": false
    },

    {
      "scenario": "Email without domain extension",
      "data": {
        "phone": "9876543210",
        "email": "user@gmail",
        "website": "https://example.com",
        "address": "MG Road",
        "city": "Mumbai",
        "state": "Maharashtra",
        "pincode": "400001"
      },
      "expected": false
    },

    {
      "scenario": "Invalid website format",
      "data": {
        "phone": "9876543210",
        "email": "user@gmail.com",
        "website": "invalid-site",
        "address": "MG Road",
        "city": "Mumbai",
        "state": "Maharashtra",
        "pincode": "400001"
      },
      "expected": false
    },

    {
      "scenario": "Website field left empty (allowed)",
      "data": {
        "phone": "9876543210",
        "email": "user@gmail.com",
        "website": "",
        "address": "MG Road",
        "city": "Mumbai",
        "state": "Maharashtra",
        "pincode": "400001"
      },
      "expected": true
    },

    {
      "scenario": "Pincode less than 6 digits",
      "data": {
        "phone": "9876543210",
        "email": "user@gmail.com",
        "website": "https://example.com",
        "address": "MG Road",
        "city": "Mumbai",
        "state": "Maharashtra",
        "pincode": "123"
      },
      "expected": false
    },

    {
      "scenario": "Pincode starting with zero",
      "data": {
        "phone": "9876543210",
        "email": "user@gmail.com",
        "website": "https://example.com",
        "address": "MG Road",
        "city": "Mumbai",
        "state": "Maharashtra",
        "pincode": "012345"
      },
      "expected": false
    }

  ]
}